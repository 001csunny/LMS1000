{
  "kind": "collectionType",
  "collectionName": "quizzes",
  "info": {
    "singularName": "quiz",
    "pluralName": "quizzes",
    "displayName": "Quiz",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Quiz": {
      "type": "string",
      "default": "Quiz"
    },
    "description": {
      "type": "text"
    },
    "file": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "lesson": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::lesson.lesson",
      "inversedBy": "quizzes"
    },
    "Answer": {
      "type": "enumeration",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "pick": {
      "type": "boolean",
      "default": false
    },
    "students": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "quizzes"
    }
  }
}
