# Environment Variables for apps/api

# Application
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=change_this_to_a_strong_secret_key
JWT_EXPIRES_IN=7d

# Database (PostgreSQL via Docker Compose)
DATABASE_URL="postgresql://lms_user:lms_password@localhost:5432/lms_db?schema=public"

# AWS S3 (optional — leave blank for graceful no-ops)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET_NAME=

# GCP Speech-to-Text (optional — leave blank to disable)
# Provide either a path to JSON key file OR inline JSON credentials
GCP_CREDENTIALS_JSON=
